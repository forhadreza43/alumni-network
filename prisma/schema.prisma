
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum TicketStatus {
  AVAILABLE
  SENT
  USED
  BLOCKED
  EXPIRED
}

enum DeliveryChannel {
  EMAIL
  SMS
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}


model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  status        UserStatus @default(ACTIVE)
  accounts      Account[]
  role          String    @default("USER")
  lastLoginAt   DateTime?
  alumniProfile        AlumniProfile?
  educationHistories   EducationHistory[]
  workExperiences      WorkExperience[]
  skills               Skill[]
  auditLogs            AuditLog[]       @relation("AuditActor")
  generatedTickets     Ticket[]         @relation("GeneratedByAdmin")
  usedTicket           Ticket?          @relation("UsedByUser")

  @@unique([email])
  @@index([role])
  @@map("user")
}

model AlumniProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  phone            String?
  dateOfBirth      DateTime?
  presentAddress   String?
  permanentAddress String?
  bio              String?
  about            String?
  linkedinUrl      String?
  facebookUrl      String?
  websiteUrl       String?
  profileCompleted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("alumni_profile")
}



model Ticket {
  id                  String       @id @default(cuid())
  ticketNumber        String       @unique
  securityHash        String?     
  generatedByAdminId  String?
  recipientEmail      String?
  recipientPhone      String?
  deliveryStatus      DeliveryStatus @default(PENDING)
  isSent              Boolean      @default(false)
  sentAt              DateTime?
  isUsed              Boolean      @default(false)
  usedAt              DateTime?
  usedByUserId        String?      @unique
  status              TicketStatus @default(AVAILABLE)
  notes               String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  generatedByAdmin User? @relation("GeneratedByAdmin", fields: [generatedByAdminId], references: [id], onDelete: SetNull)
  usedByUser       User? @relation("UsedByUser", fields: [usedByUserId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([isUsed])
  @@index([recipientEmail])
  @@index([recipientPhone])
  @@index([generatedByAdminId])
  @@map("ticket")
}


model EducationHistory {
  id              String   @id @default(cuid())
  userId          String
  institutionName String
  program          String?
  department       String?
  startYear       Int
  endYear         Int?
  studentId        String?
  batch            String?
  gradeOrResult   String?
  description     String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sortOrder])
  @@map("education_history")
}

model WorkExperience {
  id             String   @id @default(cuid())
  userId         String
  companyName    String
  designation    String?
  employmentType String?
  location       String?
  startDate      DateTime
  endDate        DateTime?
  isCurrent      Boolean  @default(false)
  description    String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sortOrder])
  @@index([companyName])
  @@map("work_experience")
}

model Skill {
  id          String   @id @default(cuid())
  userId      String
  name        String
  slug        String?
  description String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("skill")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actionType  String
  entityType  String
  entityId    String?
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  actorUser User? @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([actionType])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_log")
}
